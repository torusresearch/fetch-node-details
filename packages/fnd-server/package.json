{
  "name": "@toruslabs/fnd-server",
  "version": "15.0.0",
  "description": "",
  "private": true,
  "main": "src/index.ts",
  "scripts": {
    "serve": "tsx --watch src/index.ts",
    "prod": "node dist/index.js",
    "clean": "rimraf ./dist",
    "build": "npm run clean && npm run build:server",
    "build:server": "tsc",
    "lint": "torus-scripts lint",
    "pre-commit": "lint-staged --cwd .",
    "dev": "docker compose -f ../../docker-compose.dev.yml up --build",
    "down": "docker compose -f ../../docker-compose.dev.yml down"
  },
  "dependencies": {
    "@sentry/node": "^10.38.0",
    "@toruslabs/config": "^4.0.0",
    "@toruslabs/constants": "^15.0.0",
    "@toruslabs/fnd-base": "^15.0.0",
    "@toruslabs/loglevel-sentry": "^9.0.0",
    "celebrate": "^15.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "loglevel": "^1.9.2",
    "morgan": "^1.10.1"
  },
  "devDependencies": {
    "@toruslabs/eslint-config-node": "^5.0.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "assert": "^2.1.0",
    "cross-env": "^10.1.0",
    "rimraf": "^6.1.2",
    "tsx": "^4.21.0",
    "wait-port": "^1.1.0"
  },
  "lint-staged": {
    "*.{json,md}": [
      "prettier --write"
    ],
    "*.{js,ts}": "eslint --cache --fix"
  },
  "engines": {
    "node": ">=22.x",
    "npm": ">=10.x"
  },
  "keywords": [],
  "author": "",
  "license": "MIT"
}
